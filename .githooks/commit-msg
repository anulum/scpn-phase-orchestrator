#!/usr/bin/env bash
# SCPN Phase Orchestrator — commit message policy hook
# Install: git config core.hooksPath .githooks
# © 1998–2026 Miroslav Šotek. All rights reserved.

set -euo pipefail

COMMIT_MSG_FILE="${1:?commit message file is required}"
REQUIRED_TRAILER="Authored by Anulum Fortis & Arcane Sapience (protoscience@anulum.li)"
OLD_TRAILER_RE="^Co-Authored-By: Arcane Sapience <protoscience@anulum[.]li>$"

required_count="$(
    grep -Fxc "$REQUIRED_TRAILER" "$COMMIT_MSG_FILE" || true
)"

if [ "$required_count" -ne 1 ]; then
    {
        echo "commit-msg: expected exactly one required authorship trailer:"
        echo
        echo "  $REQUIRED_TRAILER"
    } >&2
    exit 1
fi

if grep -Eq "$OLD_TRAILER_RE" "$COMMIT_MSG_FILE"; then
    {
        echo "commit-msg: old Co-Authored-By trailer is no longer accepted."
        echo "commit-msg: use:"
        echo
        echo "  $REQUIRED_TRAILER"
    } >&2
    exit 1
fi
