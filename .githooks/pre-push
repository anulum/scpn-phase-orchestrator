#!/usr/bin/env bash
# SCPN Phase Orchestrator — pre-push hook
# Runs full CI preflight before allowing push.
# Install: git config core.hooksPath .githooks
# Skip once: git push --no-verify (use only when you know what you're doing)
# © 1998–2026 Miroslav Šotek. All rights reserved.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "pre-push: running preflight..."
py -3.12 "$REPO_ROOT/tools/preflight.py"
